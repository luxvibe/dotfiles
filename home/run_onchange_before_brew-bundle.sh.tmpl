#!/usr/bin/env bash
# Brewfile hash: {{ include (joinPath .chezmoi.sourceDir "../Brewfile") | sha256sum }}
# 上面注释用于 chezmoi 检测 Brewfile 变化并触发重跑

set -euo pipefail

command -v brew &>/dev/null || exit 0

echo "Running brew bundle..."
export HOMEBREW_NO_AUTO_UPDATE=1
export HOMEBREW_BUNDLE_FILE="$(dirname "${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi/home}")/Brewfile"
brew bundle --verbose
