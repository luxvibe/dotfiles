# ~/.config/zsh/.zshrc
# 编辑源文件：chezmoi edit ~/.config/zsh/.zshrc

# Powerlevel10k instant prompt —— 必须保持在 .zshrc 顶部附近，
# 早于任何会产生 console 输出的初始化
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

source "$ZDOTDIR/path.zsh"

# Ghostty shell integration — tmux / exec zsh 内不会自动注入，需手动加载
# 启用后 ssh-env 会把远程 TERM 设为 xterm-256color
if [[ -n $GHOSTTY_RESOURCES_DIR ]]; then
  source "$GHOSTTY_RESOURCES_DIR/shell-integration/zsh/ghostty-integration"
fi

source "$ZDOTDIR/plugins.zsh"
source "$ZDOTDIR/aliases.zsh"
source "$ZDOTDIR/functions.zsh"
[[ -f "$ZDOTDIR/ai.zsh" ]] && source "$ZDOTDIR/ai.zsh"

# 私有配置（token、proxy、GOPRIVATE 等，不入仓库）
[[ -f "$ZDOTDIR/private.zsh" ]] && source "$ZDOTDIR/private.zsh"

# ── 工具初始化（缓存输出，binary 更新时才重新生成）──────────
_cached_eval() {
    local name="$1" bin="${commands[$1]}" cache="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/$1.zsh"
    shift
    [[ -z "$bin" ]] && return
    if [[ ! -f "$cache" || "$bin" -nt "$cache" ]]; then
        mkdir -p "${cache:h}"
        "$bin" "$@" >| "$cache" 2>/dev/null || command rm -f "$cache"
    fi
    [[ -f "$cache" ]] && source "$cache"
}
_cached_eval zoxide  init zsh
_cached_eval mise    activate zsh
_cached_eval atuin   init zsh --disable-up-arrow
unfunction _cached_eval

# Powerlevel10k 提示符配置（主题本体已在 plugins.zsh 加载）
[[ -f "$HOME/.p10k.zsh" ]] && source "$HOME/.p10k.zsh"

# iTerm2 shell integration
[[ -f "$HOME/.iterm2_shell_integration.zsh" ]] && \
    source "$HOME/.iterm2_shell_integration.zsh"

# 本机局部覆盖（不入仓库）
[[ -f "$ZDOTDIR/local.zsh" ]] && source "$ZDOTDIR/local.zsh"

# 确保 .zshrc 以退出码 0 结束（某些工具如 atuin init 的末尾 bindkey 可能返回 1）
true
