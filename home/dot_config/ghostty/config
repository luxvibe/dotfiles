# Font
font-family = "MapleMono NF CN"
font-size = 14
adjust-cell-height = 16%

# Cursor
cursor-style-blink = false

# Window
window-padding-x = 8
window-padding-y = 10
window-padding-balance = true
window-save-state = always

# macOS rendering
alpha-blending = linear-corrected
macos-titlebar-style = tabs
macos-window-buttons = hidden
macos-non-native-fullscreen = visible-menu

# Mouse / keyboard
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2
macos-option-as-alt = true

# Behavior
shell-integration = detect
shell-integration-features = no-cursor,no-title,no-sudo,ssh-env
working-directory = inherit
copy-on-select = clipboard
auto-update = off
confirm-close-surface = false
resize-overlay = never
scrollback-limit = 100000000

# xterm-256color：本机无 ghostty terminfo，且与 ssh-terminfo 冲突（后者强制远端 TERM=xterm-ghostty）
# 用 xterm-256color 让 SSH 原样转发，远端无需额外 terminfo 即可正常工作
term = xterm-256color

# Visuals
theme = iterm2-default
custom-shader = "/Users/lux/.config/ghostty/shaders/shader.glsl"
background-opacity = 0.95
background-blur = true
