# direnv 全局配置

# 允许 mise 与 direnv 联动（进目录自动切 mise 版本）
# 需安装 mise：mise direnv activate >> ~/.config/direnv/direnvrc
# 或手动添加：
has mise && {
    use_mise() {
        direnv_load mise env --json "$@"
    }
}

# layout_node：进目录自动 source ./node_modules/.bin（方便直接跑 npx 命令）
layout_node() {
    local node_modules="$PWD/node_modules/.bin"
    [[ -d "$node_modules" ]] && PATH_add "$node_modules"
}

# layout_python：进目录自动 source .venv
layout_python() {
    local venv="${1:-.venv}"
    [[ -d "$venv" ]] && source "$venv/bin/activate"
}
