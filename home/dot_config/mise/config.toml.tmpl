[tools]
# ── JavaScript / TypeScript ──────────────────────────────────
node    = "lts"
pnpm    = "latest"
deno    = "latest"
bun     = "latest"

# ── Python ───────────────────────────────────────────────────
python  = "latest"
uv      = "latest"    # 现代 Python 包管理器（10× pip）

# ── Go ───────────────────────────────────────────────────────
go      = "latest"

# Go 工具链（go: backend，mise 统一管理版本）
"go:github.com/air-verse/air"                                    = "latest"  # 热重载
"go:github.com/sqlc-dev/sqlc/cmd/sqlc"                          = "latest"  # SQL → 类型安全 Go 代码
"go:github.com/golang-migrate/migrate/v4/cmd/migrate"            = "latest"  # 数据库迁移
golangci-lint                                                    = "latest"  # Go linter v2（mise 原生支持，官方推荐安装方式）
"go:mvdan.cc/sh/v3/cmd/shfmt"                                    = "latest"  # shell 格式化
actionlint                                                       = "latest"  # GitHub Actions 静态分析

# ── Rust ─────────────────────────────────────────────────────
rust    = "stable"

# ── .NET / C# ────────────────────────────────────────────────
dotnet  = "8"         # Unity 脚本 & 后端 C#；Unity 2022+ 需要 .NET 6/8

# ── JVM ──────────────────────────────────────────────────────
java    = "temurin-21"    # JDK 21 LTS
maven   = "latest"
gradle  = "latest"
kotlin  = "latest"

# ── Ruby ─────────────────────────────────────────────────────
ruby    = "3.3"

# ── PHP ──────────────────────────────────────────────────────
# php 通过 brew 安装（mise 编译安装在 macOS 上有 iconv 兼容问题）
# php = "8.3"

# ── DevOps 工具链（mise 原生支持，可按项目锁版本）────────────
buf        = "latest"   # Protobuf / gRPC 工具链
opentofu   = "latest"   # IaC 核心（terraform 开源替代）
terragrunt = "latest"   # Terraform DRY 封装
kubectl    = "latest"   # K8s CLI（可按集群锁版本，多集群必备）
helm       = "latest"   # K8s 包管理
shellcheck = "latest"   # shell 静态分析

# ── K8s 周边 CLI（版本与集群/API 对齐）──────────
kustomize   = "latest"  # K8s 配置定制
stern       = "latest"  # 多 Pod 日志聚合
k9s         = "latest"  # K8s TUI 管理器
kubeconform = "latest"  # K8s manifest 结构校验
kubectx     = "latest"  # 含 kubens，切换 context/namespace
kind        = "latest"  # K8s-in-Docker（本地测试集群）

# ── 安全 / Secrets ───────────────────────────────────────────
trivy     = "latest"    # 容器 / 代码 / IaC 安全扫描
sops      = "latest"    # secrets 文件加密，配合 git 存储敏感配置
age       = "latest"    # 现代加密工具，sops 的加密后端

# ── 其他 DevOps ──────────────────────────────────────────────
aws-vault = "latest"    # AWS 凭证安全存储与切换
awscli    = "latest"    # AWS 命令行工具
k6        = "latest"    # 性能 / 负载测试工具

[settings]
experimental = true
# 识别项目根的 .tool-versions / .mise.toml / .node-version / .python-version 等
idiomatic_version_file_enable_tools = [
    "python", "node", "go", "java", "ruby"
]