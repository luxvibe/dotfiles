#!/usr/bin/env bash
# mise 运行时首次安装（run_once，之后用 mise upgrade 更新）
set -uo pipefail   # 去掉 -e，允许部分工具安装失败不中断

if command -v mise &>/dev/null; then
    echo "Installing mise-managed runtimes..."
    # 先安装语言运行时（Go 等），再安装依赖 Go 的工具链
    mise install go python node rust 2>&1 | tail -5 || true
    mise install --yes 2>&1 | tail -10 || true
else
    echo "mise not found, skipping runtime install"
fi
